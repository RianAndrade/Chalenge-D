{% extends 'base.html.twig' %}

{% block title %}Gado - {{ cow.code }}{% endblock %}

{% block body %}
    {% include '_partials/_page_header.html.twig' with {
        title: 'Gado ' ~ cow.code,
        subtitle: 'Detalhes do animal',
        edit_path: path('app_cow_edit', {id: cow.id}),
        back_button_path: path('app_cow_index')
    } %}

    <div class="detail-card">
        <table class="table">
            <tbody>
                <tr>
                    <th>Código</th>
                    <td><strong>{{ cow.code }}</strong></td>
                </tr>
                <tr>
                    <th>Leite</th>
                    <td>{{ cow.milk|number_format(2, ',', '.') }} litros/semana</td>
                </tr>
                <tr>
                    <th>Ração</th>
                    <td>{{ cow.feed|number_format(2, ',', '.') }} kg/semana</td>
                </tr>
                <tr>
                    <th>Peso</th>
                    <td>{{ cow.weight|number_format(2, ',', '.') }} kg</td>
                </tr>
                <tr>
                    <th>Nascimento</th>
                    <td>{{ cow.birthdate|date('d/m/Y') }}</td>
                </tr>
                <tr>
                    <th>Fazenda</th>
                    <td>
                        <a href="{{ path('app_farm_show', {id: cow.farm.id}) }}" class="badge-farm text-decoration-none">{{ cow.farm.name }}</a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="d-flex gap-2 mt-3">
        <a href="{{ path('app_cow_edit', {id: cow.id}) }}" class="btn-primary-custom">
            <i class="bi bi-pencil"></i> Editar
        </a>
        <a href="{{ path('app_cow_index') }}" class="btn-secondary-custom">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>
{% endblock %}
