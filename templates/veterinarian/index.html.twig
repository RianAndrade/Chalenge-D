{% extends 'base.html.twig' %}

{% block title %}Veterinários{% endblock %}

{% block body %}
    {% include '_partials/_page_header.html.twig' with {
        title: 'Veterinários',
        subtitle: 'Gerencie os profissionais',
        add_button_label: 'Novo Veterinário',
        add_button_path: path('app_veterinarian_create')
    } %}

    {% include '_partials/_search_bar.html.twig' with {
        search: search,
        placeholder: 'Buscar por nome ou CRMV...',
        clear_path: path('app_veterinarian_index')
    } %}

    {% if veterinarians|length > 0 %}
        <div class="content-card">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>{{ knp_pagination_sortable(veterinarians, 'Nome', 'v.name') }}</th>
                            <th>{{ knp_pagination_sortable(veterinarians, 'CRMV', 'v.crmv') }}</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for veterinarian in veterinarians %}
                            <tr>
                                <td><strong>{{ veterinarian.name }}</strong></td>
                                <td>{{ veterinarian.crmv }}</td>
                                <td>
                                    {% include '_partials/_action_buttons.html.twig' with {
                                        show_path: path('app_veterinarian_show', {id: veterinarian.id}),
                                        edit_path: path('app_veterinarian_edit', {id: veterinarian.id}),
                                        delete_path: path('app_veterinarian_delete', {id: veterinarian.id}),
                                        delete_token: csrf_token('delete' ~ veterinarian.id)
                                    } %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="pagination-wrapper">
                <div></div>
                {{ knp_pagination_render(veterinarians) }}
            </div>
        </div>
    {% else %}
        <div class="content-card empty-state">
            <i class="bi bi-clipboard2-pulse"></i>
            <p>Nenhum veterinário encontrado.</p>
        </div>
    {% endif %}
{% endblock %}
