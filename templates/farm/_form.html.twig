{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
    <div class="mb-3">
        {{ form_label(form.name, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.name, {'attr': {'class': 'form-control' ~ (form.name.vars.errors|length ? ' is-invalid' : '')}}) }}
        {% for error in form.name.vars.errors %}
            <div class="invalid-feedback d-block form-error-message">{{ error.message }}</div>
        {% endfor %}
    </div>

    <div class="mb-3">
        {{ form_label(form.size, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.size, {'attr': {'class': 'form-control' ~ (form.size.vars.errors|length ? ' is-invalid' : '')}}) }}
        {% for error in form.size.vars.errors %}
            <div class="invalid-feedback d-block form-error-message">{{ error.message }}</div>
        {% endfor %}
    </div>

    <div class="mb-3">
        {{ form_label(form.manager, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.manager, {'attr': {'class': 'form-control' ~ (form.manager.vars.errors|length ? ' is-invalid' : '')}}) }}
        {% for error in form.manager.vars.errors %}
            <div class="invalid-feedback d-block form-error-message">{{ error.message }}</div>
        {% endfor %}
    </div>

    <div class="mb-3">
        {{ form_label(form.veterinarians, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.veterinarians) }}
        <div class="form-text">Segure Ctrl para selecionar múltiplos veterinários.</div>
        {% for error in form.veterinarians.vars.errors %}
            <div class="invalid-feedback d-block form-error-message">{{ error.message }}</div>
        {% endfor %}
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">{{ button_label|default('Salvar') }}</button>
        <a href="{{ path('app_farm_index') }}" class="btn btn-secondary">Cancelar</a>
    </div>
{{ form_end(form) }}
