{% extends 'base.html.twig' %}

{% block title %}Veterinários{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Veterinários</h1>
        <a href="{{ path('app_veterinarian_create') }}" class="btn btn-primary">Novo Veterinário</a>
    </div>

    <form method="get" class="mb-3">
        <div class="input-group">
            <input type="text" name="search" class="form-control" placeholder="Buscar por nome ou CRMV..." value="{{ search }}">
            <button type="submit" class="btn btn-outline-secondary">Buscar</button>
            {% if search %}
                <a href="{{ path('app_veterinarian_index') }}" class="btn btn-outline-danger">Limpar</a>
            {% endif %}
        </div>
    </form>

    {% if veterinarians|length > 0 %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>{{ knp_pagination_sortable(veterinarians, 'Nome', 'v.name') }}</th>
                        <th>{{ knp_pagination_sortable(veterinarians, 'CRMV', 'v.crmv') }}</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    {% for veterinarian in veterinarians %}
                        <tr>
                            <td>{{ veterinarian.name }}</td>
                            <td>{{ veterinarian.crmv }}</td>
                            <td class="text-end">
                                <a href="{{ path('app_veterinarian_show', {id: veterinarian.id}) }}" class="btn btn-sm btn-info">Ver</a>
                                <a href="{{ path('app_veterinarian_edit', {id: veterinarian.id}) }}" class="btn btn-sm btn-warning">Editar</a>
                                <form method="post" action="{{ path('app_veterinarian_delete', {id: veterinarian.id}) }}" class="d-inline" onsubmit="return confirm('Tem certeza que deseja excluir?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ veterinarian.id) }}">
                                    <button type="submit" class="btn btn-sm btn-danger">Excluir</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-center">
            {{ knp_pagination_render(veterinarians) }}
        </div>
    {% else %}
        <div class="alert alert-info">Nenhum veterinário encontrado.</div>
    {% endif %}
{% endblock %}
