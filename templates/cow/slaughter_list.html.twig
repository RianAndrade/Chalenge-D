{% extends 'base.html.twig' %}

{% block title %}Listagem para Abate{% endblock %}

{% block body %}
    {% include '_partials/_page_header.html.twig' with {
        title: 'Listagem para Abate',
        subtitle: 'Animais elegíveis para abate',
        back_button_path: path('app_cow_index')
    } %}

    {% if cows|length > 0 %}
        <div class="content-card">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>{{ knp_pagination_sortable(cows, 'Código', 'c.code') }}</th>
                            <th>{{ knp_pagination_sortable(cows, 'Leite (L/sem)', 'c.milk') }}</th>
                            <th>{{ knp_pagination_sortable(cows, 'Ração (kg/sem)', 'c.feed') }}</th>
                            <th>{{ knp_pagination_sortable(cows, 'Peso (kg)', 'c.weight') }}</th>
                            <th>{{ knp_pagination_sortable(cows, 'Nascimento', 'c.birthdate') }}</th>
                            <th>Fazenda</th>
                            <th>Motivos</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for cow in cows %}
                            <tr>
                                <td><strong>{{ cow.code }}</strong></td>
                                <td>{{ cow.milk|number_format(2, ',', '.') }}</td>
                                <td>{{ cow.feed|number_format(2, ',', '.') }}</td>
                                <td>{{ cow.weight|number_format(2, ',', '.') }}</td>
                                <td>{{ cow.birthdate|date('d/m/Y') }}</td>
                                <td><span class="badge-farm">{{ cow.farm.name }}</span></td>
                                <td>
                                    <ul class="mb-0 small" style="padding-left:16px;">
                                        {% for reason in cow.slaughterReasons %}
                                            <li>{{ reason }}</li>
                                        {% endfor %}
                                    </ul>
                                </td>
                                <td class="text-end">
                                    <form method="post" action="{{ path('app_cow_slaughter', {id: cow.id}) }}" class="d-inline" onsubmit="return confirm('Tem certeza que deseja enviar este animal para abate?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('slaughter' ~ cow.id) }}">
                                        <button type="submit" class="btn-danger-custom" style="padding:6px 14px; font-size:12px;">
                                            <i class="bi bi-exclamation-triangle"></i> Abater
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="pagination-wrapper">
                <div></div>
                {{ knp_pagination_render(cows) }}
            </div>
        </div>
    {% else %}
        <div class="content-card empty-state">
            <i class="bi bi-check-circle"></i>
            <p>Nenhum animal elegível para abate.</p>
        </div>
    {% endif %}
{% endblock %}
