{# Usage: {% include '_partials/_report_filter.html.twig' with {action: path('route'), csv_action: path('csv_route'), filters: filters, farms: farms, fields: ['farm', 'milk_min', 'milk_max']} %} #}

<div class="content-card mb-4">
    <div class="p-3 border-bottom" style="background: var(--bg-alt);">
        <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-funnel" style="color: var(--primary);"></i>
                <strong style="font-size: 14px;">Filtros</strong>
            </div>
            {% if csv_action is defined and csv_action %}
                <a href="{{ csv_action }}{% if filters|default({}) %}?{% for key, val in filters %}{% if val is not null and val != '' %}{{ key }}={{ val }}{% if not loop.last %}&{% endif %}{% endif %}{% endfor %}{% endif %}" class="btn-csv">
                    <i class="bi bi-filetype-csv"></i> Exportar CSV
                </a>
            {% endif %}
        </div>
    </div>
    <div class="p-3">
        <form method="get" action="{{ action }}">
            <div class="row g-3 align-items-end">
                {% if 'farm' in fields %}
                    <div class="col-md-3">
                        <label class="form-label">Fazenda</label>
                        <select name="farm" class="form-select form-select-sm">
                            <option value="">Todas</option>
                            {% for farm in farms %}
                                <option value="{{ farm.id }}" {{ filters.farm == farm.id ? 'selected' }}>{{ farm.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                {% endif %}

                {% if 'milk_min' in fields %}
                    <div class="col-md-2">
                        <label class="form-label">Leite min (L/sem)</label>
                        <input type="number" step="0.01" name="milk_min" class="form-control form-control-sm" value="{{ filters.milk_min }}" placeholder="0">
                    </div>
                {% endif %}

                {% if 'milk_max' in fields %}
                    <div class="col-md-2">
                        <label class="form-label">Leite max (L/sem)</label>
                        <input type="number" step="0.01" name="milk_max" class="form-control form-control-sm" value="{{ filters.milk_max }}" placeholder="999">
                    </div>
                {% endif %}

                {% if 'feed_min' in fields %}
                    <div class="col-md-2">
                        <label class="form-label">Ração min (kg/sem)</label>
                        <input type="number" step="0.01" name="feed_min" class="form-control form-control-sm" value="{{ filters.feed_min }}" placeholder="0">
                    </div>
                {% endif %}

                {% if 'feed_max' in fields %}
                    <div class="col-md-2">
                        <label class="form-label">Ração max (kg/sem)</label>
                        <input type="number" step="0.01" name="feed_max" class="form-control form-control-sm" value="{{ filters.feed_max }}" placeholder="999">
                    </div>
                {% endif %}

                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn-primary-custom btn-sm">
                        <i class="bi bi-funnel"></i> Filtrar
                    </button>
                    <a href="{{ action }}" class="btn-secondary-custom btn-sm">
                        <i class="bi bi-x-lg"></i> Limpar
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>
