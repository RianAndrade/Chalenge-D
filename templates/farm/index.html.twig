{% extends 'base.html.twig' %}

{% block title %}Fazendas{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Fazendas</h1>
        <a href="{{ path('app_farm_create') }}" class="btn btn-primary">Nova Fazenda</a>
    </div>

    <form method="get" class="mb-3">
        <div class="input-group">
            <input type="text" name="search" class="form-control" placeholder="Buscar por nome ou responsável..." value="{{ search }}">
            <button type="submit" class="btn btn-outline-secondary">Buscar</button>
            {% if search %}
                <a href="{{ path('app_farm_index') }}" class="btn btn-outline-danger">Limpar</a>
            {% endif %}
        </div>
    </form>

    {% if farms|length > 0 %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>{{ knp_pagination_sortable(farms, 'Nome', 'f.name') }}</th>
                        <th>{{ knp_pagination_sortable(farms, 'Tamanho (HA)', 'f.size') }}</th>
                        <th>{{ knp_pagination_sortable(farms, 'Responsável', 'f.manager') }}</th>
                        <th>Veterinários</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    {% for farm in farms %}
                        <tr>
                            <td>{{ farm.name }}</td>
                            <td>{{ farm.size|number_format(2, ',', '.') }}</td>
                            <td>{{ farm.manager }}</td>
                            <td>
                                {% for vet in farm.veterinarians %}
                                    <span class="badge bg-secondary">{{ vet.name }}</span>
                                {% else %}
                                    <span class="text-muted">Nenhum</span>
                                {% endfor %}
                            </td>
                            <td class="text-end">
                                <a href="{{ path('app_farm_show', {id: farm.id}) }}" class="btn btn-sm btn-info">Ver</a>
                                <a href="{{ path('app_farm_edit', {id: farm.id}) }}" class="btn btn-sm btn-warning">Editar</a>
                                <form method="post" action="{{ path('app_farm_delete', {id: farm.id}) }}" class="d-inline" onsubmit="return confirm('Tem certeza que deseja excluir?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ farm.id) }}">
                                    <button type="submit" class="btn btn-sm btn-danger">Excluir</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-center">
            {{ knp_pagination_render(farms) }}
        </div>
    {% else %}
        <div class="alert alert-info">Nenhuma fazenda encontrada.</div>
    {% endif %}
{% endblock %}
