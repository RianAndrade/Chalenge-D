{% extends 'base.html.twig' %}

{% block title %}Dev Tools{% endblock %}

{% block body %}
    {% include '_partials/_page_header.html.twig' with {
        title: 'Dev Tools',
        subtitle: 'Ferramentas disponíveis apenas em ambiente de desenvolvimento'
    } %}

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-card-body">
                    <div class="stat-card-title">Veterinários</div>
                    <div class="stat-card-value">{{ veterinarianCount }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-card-body">
                    <div class="stat-card-title">Fazendas</div>
                    <div class="stat-card-value">{{ farmCount }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-card-body">
                    <div class="stat-card-title">Vacas</div>
                    <div class="stat-card-value">{{ cowCount }}</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h5 class="card-title mb-3">Database Seeder</h5>
            <p class="text-muted mb-3">
                Cria 10 veterinários, 5 fazendas e 100 vacas com dados aleatórios.
            </p>
            <form action="{{ path('app_dev_seed') }}" method="post">
                <input type="hidden" name="_token" value="{{ csrf_token('seed') }}">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-database-fill-gear"></i> Semear Dados
                </button>
            </form>
        </div>
    </div>
{% endblock %}
