{% extends 'base.html.twig' %}

{% block title %}Relatório de Animais Abatidos{% endblock %}

{% block body %}
    {% include '_partials/_page_header.html.twig' with {
        title: 'Animais Abatidos',
        subtitle: 'Relatório de abates realizados',
        back_button_path: path('app_dashboard')
    } %}

    {% if cows|length > 0 %}
        <div class="content-card">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>{{ knp_pagination_sortable(cows, 'Código', 'c.code') }}</th>
                            <th>Fazenda</th>
                            <th>{{ knp_pagination_sortable(cows, 'Nascimento', 'c.birthdate') }}</th>
                            <th>{{ knp_pagination_sortable(cows, 'Data de Abate', 'c.slaughter') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for cow in cows %}
                            <tr>
                                <td><strong>{{ cow.code }}</strong></td>
                                <td><span class="badge-farm">{{ cow.farm.name }}</span></td>
                                <td>{{ cow.birthdate|date('d/m/Y') }}</td>
                                <td>{{ cow.slaughter|date('d/m/Y') }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="pagination-wrapper">
                <div></div>
                {{ knp_pagination_render(cows) }}
            </div>
        </div>
    {% else %}
        <div class="content-card empty-state">
            <i class="bi bi-journal-text"></i>
            <p>Nenhum animal abatido encontrado.</p>
        </div>
    {% endif %}
{% endblock %}
