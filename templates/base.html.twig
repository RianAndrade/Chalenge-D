<!DOCTYPE html>
<html lang="pt-BR">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Fazenda Bovina{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🐄</text></svg>">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_veterinarian_index') }}">Fazenda Bovina</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_veterinarian_index') }}">Veterinários</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_farm_index') }}">Fazendas</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_cow_index') }}">Gados</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <div class="container">
            {% for type in ['success', 'error', 'warning', 'info'] %}
                {% for message in app.flashes(type) %}
                    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </div>

        <div class="modal fade" id="errorModal" tabindex="-1" aria-labelledby="errorModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title" id="errorModalLabel">Erro de validação</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
                    </div>
                    <div class="modal-body">
                        <ul id="errorModalList" class="mb-0"></ul>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const errors = document.querySelectorAll('.form-error-message');
                if (errors.length > 0) {
                    const list = document.getElementById('errorModalList');
                    errors.forEach(function (el) {
                        const li = document.createElement('li');
                        li.textContent = el.textContent;
                        list.appendChild(li);
                    });
                    const modal = new bootstrap.Modal(document.getElementById('errorModal'));
                    modal.show();
                }
            });
        </script>
    </body>
</html>
