{% extends 'base.html.twig' %}

{% block title %}Fazendas{% endblock %}

{% block body %}
    {% include '_partials/_page_header.html.twig' with {
        title: 'Fazendas',
        subtitle: 'Gerencie as propriedades',
        add_button_label: 'Nova Fazenda',
        add_button_path: path('app_farm_create')
    } %}

    <div class="content-card mb-4">
        <div class="p-3 border-bottom" style="background: var(--bg-alt);">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-funnel" style="color: var(--primary);"></i>
                <strong style="font-size: 14px;">Filtros</strong>
            </div>
        </div>
        <div class="p-3">
            <form method="get" action="{{ path('app_farm_index') }}">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label">Busca</label>
                        <input type="text" name="search" class="form-control form-control-sm" placeholder="Nome ou responsável..." value="{{ filters.search }}">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Veterinário</label>
                        <select name="veterinarian" class="form-select form-select-sm">
                            <option value="">Todos</option>
                            {% for vet in veterinarians %}
                                <option value="{{ vet.id }}" {{ filters.veterinarian == vet.id ? 'selected' }}>{{ vet.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Tamanho min (HA)</label>
                        <input type="number" step="0.01" name="size_min" class="form-control form-control-sm" value="{{ filters.size_min }}" placeholder="0">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Tamanho max (HA)</label>
                        <input type="number" step="0.01" name="size_max" class="form-control form-control-sm" value="{{ filters.size_max }}" placeholder="999">
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button type="submit" class="btn-primary-custom btn-sm">
                            <i class="bi bi-funnel"></i> Filtrar
                        </button>
                        <a href="{{ path('app_farm_index') }}" class="btn-secondary-custom btn-sm">
                            <i class="bi bi-x-lg"></i> Limpar
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    {% if farms|length > 0 %}
        <div class="content-card">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>{{ knp_pagination_sortable(farms, 'Nome', 'f.name') }}</th>
                            <th>{{ knp_pagination_sortable(farms, 'Tamanho (HA)', 'f.size') }}</th>
                            <th>{{ knp_pagination_sortable(farms, 'Responsável', 'f.manager') }}</th>
                            <th>Veterinários</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for farm in farms %}
                            <tr>
                                <td><strong>{{ farm.name }}</strong></td>
                                <td>{{ farm.size|number_format(2, ',', '.') }}</td>
                                <td>{{ farm.manager }}</td>
                                <td>
                                    {% for vet in farm.veterinarians %}
                                        <span class="badge-vet">{{ vet.name }}</span>
                                    {% else %}
                                        <span class="text-muted" style="font-size:12px;">Nenhum</span>
                                    {% endfor %}
                                </td>
                                <td>
                                    {% include '_partials/_action_buttons.html.twig' with {
                                        show_path: path('app_farm_show', {id: farm.id}),
                                        edit_path: path('app_farm_edit', {id: farm.id}),
                                        delete_path: path('app_farm_delete', {id: farm.id}),
                                        delete_token: csrf_token('delete' ~ farm.id)
                                    } %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="pagination-wrapper">
                <div></div>
                {{ knp_pagination_render(farms) }}
            </div>
        </div>
    {% else %}
        <div class="content-card empty-state">
            <i class="bi bi-building"></i>
            <p>Nenhuma fazenda encontrada.</p>
        </div>
    {% endif %}
{% endblock %}
