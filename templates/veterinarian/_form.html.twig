{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
    <div class="mb-3">
        {{ form_label(form.name, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.name, {'attr': {'class': 'form-control' ~ (form.name.vars.errors|length ? ' is-invalid' : '')}}) }}
        {% for error in form.name.vars.errors %}
            <div class="invalid-feedback d-block form-error-message">{{ error.message }}</div>
        {% endfor %}
    </div>

    <div class="mb-3">
        {{ form_label(form.crmv, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.crmv, {'attr': {'class': 'form-control' ~ (form.crmv.vars.errors|length ? ' is-invalid' : '')}}) }}
        {% for error in form.crmv.vars.errors %}
            <div class="invalid-feedback d-block form-error-message">{{ error.message }}</div>
        {% endfor %}
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">{{ button_label|default('Salvar') }}</button>
        <a href="{{ path('app_veterinarian_index') }}" class="btn btn-secondary">Cancelar</a>
    </div>
{{ form_end(form) }}
