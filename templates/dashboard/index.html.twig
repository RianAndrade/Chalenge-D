{% extends 'base.html.twig' %}

{% block title %}Início - Fazenda Bovina{% endblock %}

{% block body %}
    {% include '_partials/_page_header.html.twig' with {title: 'Dashboard', subtitle: 'Relatório semanal da produção'} %}

    <div class="row g-4">
        <div class="col-md-4">
            {% include '_partials/_stat_card.html.twig' with {
                label: 'Leite Produzido',
                value: totalMilk|number_format(2, ',', '.'),
                unit: 'L/semana',
                icon: 'bi-droplet-fill',
                color: 'green',
                footer: 'Total por semana (animais vivos)',
                bar_color: 'var(--primary)',
                bar_width: 72
            } %}
        </div>

        <div class="col-md-4">
            {% include '_partials/_stat_card.html.twig' with {
                label: 'Ração Necessária',
                value: totalFeed|number_format(2, ',', '.'),
                unit: 'kg/semana',
                icon: 'bi-basket-fill',
                color: 'accent',
                footer: 'Total por semana (animais vivos)',
                bar_color: 'var(--accent)',
                bar_width: 55
            } %}
        </div>

        <div class="col-md-4">
            {% include '_partials/_stat_card.html.twig' with {
                label: 'Animais Jovens com Alta Ração',
                value: youngHighFeedCount,
                unit: 'animais',
                icon: 'bi-heart-pulse-fill',
                color: 'dark',
                footer: 'Até 1 ano e mais de 500kg ração/semana',
                bar_color: 'var(--sidebar-bg)',
                bar_width: 35
            } %}
        </div>
    </div>
{% endblock %}
