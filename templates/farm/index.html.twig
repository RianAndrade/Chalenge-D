{% extends 'base.html.twig' %}

{% block title %}Fazendas{% endblock %}

{% block body %}
    {% include '_partials/_page_header.html.twig' with {
        title: 'Fazendas',
        subtitle: 'Gerencie as propriedades',
        add_button_label: 'Nova Fazenda',
        add_button_path: path('app_farm_create')
    } %}

    {% include '_partials/_search_bar.html.twig' with {
        search: search,
        placeholder: 'Buscar por nome ou responsável...',
        clear_path: path('app_farm_index')
    } %}

    {% if farms|length > 0 %}
        <div class="content-card">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>{{ knp_pagination_sortable(farms, 'Nome', 'f.name') }}</th>
                            <th>{{ knp_pagination_sortable(farms, 'Tamanho (HA)', 'f.size') }}</th>
                            <th>{{ knp_pagination_sortable(farms, 'Responsável', 'f.manager') }}</th>
                            <th>Veterinários</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for farm in farms %}
                            <tr>
                                <td><strong>{{ farm.name }}</strong></td>
                                <td>{{ farm.size|number_format(2, ',', '.') }}</td>
                                <td>{{ farm.manager }}</td>
                                <td>
                                    {% for vet in farm.veterinarians %}
                                        <span class="badge-vet">{{ vet.name }}</span>
                                    {% else %}
                                        <span class="text-muted" style="font-size:12px;">Nenhum</span>
                                    {% endfor %}
                                </td>
                                <td>
                                    {% include '_partials/_action_buttons.html.twig' with {
                                        show_path: path('app_farm_show', {id: farm.id}),
                                        edit_path: path('app_farm_edit', {id: farm.id}),
                                        delete_path: path('app_farm_delete', {id: farm.id}),
                                        delete_token: csrf_token('delete' ~ farm.id)
                                    } %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="pagination-wrapper">
                <div></div>
                {{ knp_pagination_render(farms) }}
            </div>
        </div>
    {% else %}
        <div class="content-card empty-state">
            <i class="bi bi-building"></i>
            <p>Nenhuma fazenda encontrada.</p>
        </div>
    {% endif %}
{% endblock %}
