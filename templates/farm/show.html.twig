{% extends 'base.html.twig' %}

{% block title %}Fazenda - {{ farm.name }}{% endblock %}

{% block body %}
    {% include '_partials/_page_header.html.twig' with {
        title: farm.name,
        subtitle: 'Detalhes da fazenda',
        back_button_path: path('app_farm_index')
    } %}

    <div class="detail-card">
        <table class="table">
            <tbody>
                <tr>
                    <th>Nome</th>
                    <td><strong>{{ farm.name }}</strong></td>
                </tr>
                <tr>
                    <th>Tamanho</th>
                    <td>{{ farm.size|number_format(2, ',', '.') }} HA</td>
                </tr>
                <tr>
                    <th>Responsável</th>
                    <td>{{ farm.manager }}</td>
                </tr>
                <tr>
                    <th>Veterinários</th>
                    <td>
                        {% for vet in farm.veterinarians %}
                            <span class="badge-vet">{{ vet.name }}</span>
                        {% else %}
                            <span class="text-muted" style="font-size:13px;">Nenhum veterinário vinculado</span>
                        {% endfor %}
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="d-flex gap-2 mt-3">
        <a href="{{ path('app_farm_edit', {id: farm.id}) }}" class="btn-primary-custom">
            <i class="bi bi-pencil"></i> Editar
        </a>
        <a href="{{ path('app_farm_index') }}" class="btn-secondary-custom">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>
{% endblock %}
