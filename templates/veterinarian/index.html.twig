{% extends 'base.html.twig' %}

{% block title %}Veterinários{% endblock %}

{% block body %}
    {% include '_partials/_page_header.html.twig' with {
        title: 'Veterinários',
        subtitle: 'Gerencie os profissionais',
        add_button_label: 'Novo Veterinário',
        add_button_path: path('app_veterinarian_create')
    } %}

    <div class="content-card mb-4">
        <div class="p-3 border-bottom" style="background: var(--bg-alt);">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-funnel" style="color: var(--primary);"></i>
                <strong style="font-size: 14px;">Filtros</strong>
            </div>
        </div>
        <div class="p-3">
            <form method="get" action="{{ path('app_veterinarian_index') }}">
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Busca</label>
                        <input type="text" name="search" class="form-control form-control-sm" placeholder="Nome ou CRMV..." value="{{ filters.search }}">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Fazenda</label>
                        <select name="farm" class="form-select form-select-sm">
                            <option value="">Todas</option>
                            {% for farm in farms %}
                                <option value="{{ farm.id }}" {{ filters.farm == farm.id ? 'selected' }}>{{ farm.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button type="submit" class="btn-primary-custom btn-sm">
                            <i class="bi bi-funnel"></i> Filtrar
                        </button>
                        <a href="{{ path('app_veterinarian_index') }}" class="btn-secondary-custom btn-sm">
                            <i class="bi bi-x-lg"></i> Limpar
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    {% if veterinarians|length > 0 %}
        <div class="content-card">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>{{ knp_pagination_sortable(veterinarians, 'Nome', 'v.name') }}</th>
                            <th>{{ knp_pagination_sortable(veterinarians, 'CRMV', 'v.crmv') }}</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for veterinarian in veterinarians %}
                            <tr>
                                <td><strong>{{ veterinarian.name }}</strong></td>
                                <td>{{ veterinarian.crmv }}</td>
                                <td>
                                    {% include '_partials/_action_buttons.html.twig' with {
                                        show_path: path('app_veterinarian_show', {id: veterinarian.id}),
                                        edit_path: path('app_veterinarian_edit', {id: veterinarian.id}),
                                        delete_path: path('app_veterinarian_delete', {id: veterinarian.id}),
                                        delete_token: csrf_token('delete' ~ veterinarian.id)
                                    } %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="pagination-wrapper">
                <div></div>
                {{ knp_pagination_render(veterinarians) }}
            </div>
        </div>
    {% else %}
        <div class="content-card empty-state">
            <i class="bi bi-clipboard2-pulse"></i>
            <p>Nenhum veterinário encontrado.</p>
        </div>
    {% endif %}
{% endblock %}
