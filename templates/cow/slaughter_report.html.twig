{% extends 'base.html.twig' %}

{% block title %}Relatório de Animais Abatidos{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Relatório de Animais Abatidos</h1>
        <a href="{{ path('app_dashboard') }}" class="btn btn-secondary">Voltar</a>
    </div>

    {% if cows|length > 0 %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>{{ knp_pagination_sortable(cows, 'Código', 'c.code') }}</th>
                        <th>Fazenda</th>
                        <th>{{ knp_pagination_sortable(cows, 'Nascimento', 'c.birthdate') }}</th>
                        <th>{{ knp_pagination_sortable(cows, 'Data de Abate', 'c.slaughter') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for cow in cows %}
                        <tr>
                            <td>{{ cow.code }}</td>
                            <td>{{ cow.farm.name }}</td>
                            <td>{{ cow.birthdate|date('d/m/Y') }}</td>
                            <td>{{ cow.slaughter|date('d/m/Y') }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-center">
            {{ knp_pagination_render(cows) }}
        </div>
    {% else %}
        <div class="alert alert-info">Nenhum animal abatido encontrado.</div>
    {% endif %}
{% endblock %}
