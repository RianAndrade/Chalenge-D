{% extends 'base.html.twig' %}

{% block title %}Gados{% endblock %}

{% block body %}
    {% include '_partials/_page_header.html.twig' with {
        title: 'Gados',
        subtitle: 'Gerencie o rebanho',
        add_button_label: 'Novo Gado',
        add_button_path: path('app_cow_create')
    } %}

    <div class="content-card mb-4">
        <div class="p-3 border-bottom" style="background: var(--bg-alt);">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-funnel" style="color: var(--primary);"></i>
                <strong style="font-size: 14px;">Filtros</strong>
            </div>
        </div>
        <div class="p-3">
            <form method="get" action="{{ path('app_cow_index') }}">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label">Busca</label>
                        <input type="text" name="search" class="form-control form-control-sm" placeholder="Código ou fazenda..." value="{{ filters.search }}">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Fazenda</label>
                        <select name="farm" class="form-select form-select-sm">
                            <option value="">Todas</option>
                            {% for farm in farms %}
                                <option value="{{ farm.id }}" {{ filters.farm == farm.id ? 'selected' }}>{{ farm.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Status</label>
                        <select name="status" class="form-select form-select-sm">
                            <option value="">Todos</option>
                            <option value="alive" {{ filters.status == 'alive' ? 'selected' }}>Vivo</option>
                            <option value="slaughtered" {{ filters.status == 'slaughtered' ? 'selected' }}>Abatido</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Leite min (L/sem)</label>
                        <input type="number" step="0.01" name="milk_min" class="form-control form-control-sm" value="{{ filters.milk_min }}" placeholder="0">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Leite max (L/sem)</label>
                        <input type="number" step="0.01" name="milk_max" class="form-control form-control-sm" value="{{ filters.milk_max }}" placeholder="999">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Peso min (kg)</label>
                        <input type="number" step="0.01" name="weight_min" class="form-control form-control-sm" value="{{ filters.weight_min }}" placeholder="0">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Peso max (kg)</label>
                        <input type="number" step="0.01" name="weight_max" class="form-control form-control-sm" value="{{ filters.weight_max }}" placeholder="999">
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button type="submit" class="btn-primary-custom btn-sm">
                            <i class="bi bi-funnel"></i> Filtrar
                        </button>
                        <a href="{{ path('app_cow_index') }}" class="btn-secondary-custom btn-sm">
                            <i class="bi bi-x-lg"></i> Limpar
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    {% if cows|length > 0 %}
        <div class="content-card">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>{{ knp_pagination_sortable(cows, 'Código', 'c.code') }}</th>
                            <th>{{ knp_pagination_sortable(cows, 'Leite (L/sem)', 'c.milk') }}</th>
                            <th>{{ knp_pagination_sortable(cows, 'Ração (kg/sem)', 'c.feed') }}</th>
                            <th>{{ knp_pagination_sortable(cows, 'Peso (kg)', 'c.weight') }}</th>
                            <th>{{ knp_pagination_sortable(cows, 'Nascimento', 'c.birthdate') }}</th>
                            <th>Fazenda</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for cow in cows %}
                            <tr>
                                <td><strong>{{ cow.code }}</strong></td>
                                <td>{{ cow.milk|number_format(2, ',', '.') }}</td>
                                <td>{{ cow.feed|number_format(2, ',', '.') }}</td>
                                <td>{{ cow.weight|number_format(2, ',', '.') }}</td>
                                <td>{{ cow.birthdate|date('d/m/Y') }}</td>
                                <td><span class="badge-farm">{{ cow.farm ? cow.farm.name : '—' }}</span></td>
                                <td>
                                    {% include '_partials/_action_buttons.html.twig' with {
                                        show_path: path('app_cow_show', {id: cow.id}),
                                        edit_path: path('app_cow_edit', {id: cow.id}),
                                        delete_path: path('app_cow_delete', {id: cow.id}),
                                        delete_token: csrf_token('delete' ~ cow.id)
                                    } %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="pagination-wrapper">
                <div></div>
                {{ knp_pagination_render(cows) }}
            </div>
        </div>
    {% else %}
        <div class="content-card empty-state">
            <i class="bi bi-tags"></i>
            <p>Nenhum gado encontrado.</p>
        </div>
    {% endif %}
{% endblock %}
